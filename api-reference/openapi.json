        "responses": {
          "200": { "description": "Report URL", "content": { "application/json": { "schema": { "properties": { "success": { "type": "boolean" }, "data": { "type": "object", "properties": { "report_url": { "type": "string", "format": "uri", "description": "Presigned S3 URL, valid for 120 seconds" } } } } } } } }
        }
      }
