    "/api/solutions/": {
      "post": {
        "tags": ["AI Solutions"],
        "summary": "Generate accessibility fix",
        "description": "Uses Google Gemini 2.0 Flash to generate a code fix for an accessibility issue. Result is cached in S3 for 180 days.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["issue_id", "html_snippet"],
                "properties": {
                  "issue_id": { "type": "string", "description": "Axe rule ID, e.g. `image-alt`" },
                  "html_snippet": { "type": "string", "description": "The HTML element with the issue" },
                  "issue_description": { "type": "string" },
                  "page_url": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI-generated fix",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "current_code": { "type": "string", "example": "<img src='photo.jpg'>" },
                        "correct_code": { "type": "string", "example": "<img src='photo.jpg' alt='Team photo'>" },
                        "explanation": { "type": "string" },
                        "solution_url": { "type": "string", "format": "uri", "description": "Presigned S3 URL to the cached solution" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
