{
  "openapi": "3.1.0",
  "info": {
    "title": "Webyes Auditor API",
    "version": "1.0.0",
    "description": "REST API for the Webyes Auditor platform. Handles authentication, website management, accessibility/performance scans, billing, RUM, and reports.\n\n## Authentication\n\nAll protected endpoints require a JWT bearer token obtained from `/api/auth/login`.\n\n```\nAuthorization: Bearer <access_token>\n```\n\n## Response Format\n\nAll endpoints return a consistent JSON envelope:\n\n```json\n{ \"success\": true, \"data\": { ... } }\n{ \"success\": false, \"message\": \"Error description\" }\n```"
  },
  "servers": [
    { "url": "http://localhost:8000", "description": "Local development" },
    { "url": "https://api.staging.webyes.com", "description": "Staging" },
    { "url": "https://api.webyes.com", "description": "Production" }
  ],
  "security": [{ "bearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT (RS256)"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Invalid credentials" }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email_verified": { "type": "boolean" },
          "user_status": { "type": "string", "enum": ["active", "inactive", "marked_for_delete", "archived", "expired", "canceled"] },
          "is_from_suit": { "type": "boolean", "description": "true = full-suite user, false = a11y user" },
          "created_time": { "type": "string", "format": "date-time" }
        }
      },
      "Website": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "website_url": { "type": "string", "format": "uri" },
          "website_name": { "type": "string" },
          "organisation_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "enum": ["active", "inactive"] },
          "region_id": { "type": "string", "format": "uuid", "nullable": true },
          "rum_status": { "type": "string", "nullable": true },
          "enable_aaa": { "type": "boolean", "nullable": true },
          "created_time": { "type": "string", "format": "date-time" }
        }
      },
      "WebsiteAudit": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "website_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "enum": ["scheduled", "in_progress", "completed", "failed", "canceled"] },
          "scan_type": { "type": "string", "enum": ["quick", "full", "custom"] },
          "audit_start_time": { "type": "string", "format": "date-time" },
          "audit_end_time": { "type": "string", "format": "date-time", "nullable": true },
          "is_scheduled_scan": { "type": "boolean" },
          "total_credits_used": { "type": "integer", "nullable": true }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "recurrance": { "type": "string", "enum": ["monthly", "yearly"], "nullable": true },
          "scan_limit": { "type": "integer", "nullable": true },
          "website_limit": { "type": "integer", "nullable": true },
          "user_limit": { "type": "integer", "nullable": true },
          "features": { "type": "object" },
          "status": { "type": "string", "enum": ["active", "inactive"] }
        }
      },
      "Organisation": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "organisation_name": { "type": "string" },
          "status": { "type": "string" },
          "audit_max_number_of_pages": { "type": "integer", "nullable": true },
          "created_time": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "tags": [
    { "name": "Health", "description": "Service health check" },
    { "name": "Auth", "description": "Login, logout, password reset, and OAuth flows (Google, Microsoft, Cognito)" },
    { "name": "Users", "description": "User registration, profile management, email verification, and team invitations" },
    { "name": "Websites", "description": "Add, update, delete, and search websites registered for auditing" },
    { "name": "Scans", "description": "Trigger and manage website audit scans" },
    { "name": "Results", "description": "Retrieve audit results and accessibility data" },
    { "name": "Reports", "description": "Generate and retrieve audit reports" },
    { "name": "AI Solutions", "description": "Gemini AI-powered accessibility fix suggestions" },
    { "name": "Billing", "description": "Stripe subscription management, checkout, and transaction history" },
    { "name": "Plans", "description": "Available subscription plans" },
    { "name": "Organisations", "description": "Organisation CRUD and member management" },
    { "name": "Scan Schedules", "description": "Configure recurring automated scans" },
    { "name": "Uptime Monitor", "description": "Monitor website availability" },
    { "name": "RUM", "description": "Real User Monitoring — metrics and configuration" },
    { "name": "Search Console", "description": "Google Search Console OAuth and data" },
    { "name": "Regions", "description": "Available scan server regions" },
    { "name": "Offboarding", "description": "Account deletion and cancellation" }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns 200 if the service is running.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "status": { "type": "string", "example": "ok" } } }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with email and password",
        "description": "Authenticates a user with email and password. Returns a JWT access token. Rate limited to 10 requests/min per IP.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "dev@webyes.com" },
                  "password": { "type": "string", "example": "securepassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {
                      "type": "object",
                      "properties": {
                        "access_token": { "type": "string", "example": "eyJhbGciOiJSUzI1NiIs..." },
                        "user": { "$ref": "#/components/schemas/UserProfile" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "429": { "description": "Rate limit exceeded" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout",
        "description": "Invalidates the current JWT token in Redis. Token becomes immediately unusable.",
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request password reset",
        "description": "Sends a password reset email to the provided address.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": { "email": { "type": "string", "format": "email" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset email sent if account exists" }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Complete password reset",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "new_password"],
                "properties": {
                  "token": { "type": "string" },
                  "new_password": { "type": "string", "minLength": 8 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successfully" },
          "400": { "description": "Invalid or expired token" }
        }
      }
    },
    "/api/auth/refresh-token": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "description": "Exchange a refresh token for a new access token.",
        "responses": {
          "200": { "description": "New access token issued" }
        }
      }
    },
    "/api/auth/google-auth": {
      "get": {
        "tags": ["Auth"],
        "summary": "Initiate Google OAuth",
        "description": "Redirects the user to Google's OAuth consent screen. Scopes: openid, profile, email.",
        "security": [],
        "responses": {
          "302": { "description": "Redirect to Google OAuth" }
        }
      }
    },
    "/api/auth/google-auth/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Google OAuth callback",
        "description": "Handles the OAuth callback from Google. Creates or finds the user, issues a local JWT, and redirects to the frontend with `?token=<jwt>`.",
        "security": [],
        "parameters": [
          { "name": "code", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "state", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "302": { "description": "Redirect to frontend with token" }
        }
      }
    },
    "/api/auth/microsoft-auth": {
      "get": {
        "tags": ["Auth"],
        "summary": "Initiate Microsoft OAuth",
        "description": "Redirects to Microsoft login. Scopes: openid, profile, email, User.Read.",
        "security": [],
        "responses": {
          "302": { "description": "Redirect to Microsoft login" }
        }
      }
    },
    "/api/auth/microsoft-auth/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Microsoft OAuth callback",
        "security": [],
        "parameters": [
          { "name": "code", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "302": { "description": "Redirect to frontend with token" }
        }
      }
    },
    "/api/user/": {
      "post": {
        "tags": ["Users"],
        "summary": "Create user account",
        "description": "Registers a new user. Rate limited to 10 requests/min per IP.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "first_name"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "user_type": { "type": "string", "enum": ["webowner", "agencyowner", "other"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "409": { "description": "Email already registered" }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Update user profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "first_name": { "type": "string" },
                  "last_name": { "type": "string" },
                  "phone_number": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Profile updated" }
        }
      }
    },
    "/api/user/me/": {
      "get": {
        "tags": ["Users"],
        "summary": "Get current user",
        "description": "Returns the authenticated user's profile, organisation, role, and permissions.",
        "responses": {
          "200": {
            "description": "Current user data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": { "$ref": "#/components/schemas/UserProfile" },
                        "organisation": { "$ref": "#/components/schemas/Organisation" },
                        "permissions": { "type": "array", "items": { "type": "string" }, "example": ["settings:website:add", "scan:full_scan:add"] }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/user/verify-email/": {
      "post": {
        "tags": ["Users"],
        "summary": "Send email OTP",
        "description": "Sends a one-time password to the user's email for verification. Rate limited.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["email"], "properties": { "email": { "type": "string", "format": "email" } } }
            }
          }
        },
        "responses": { "200": { "description": "OTP sent" } }
      }
    },
    "/api/user/verify-email-otp/": {
      "post": {
        "tags": ["Users"],
        "summary": "Verify email OTP",
        "description": "Validates the OTP code and marks the user's email as verified.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["email", "otp"], "properties": { "email": { "type": "string" }, "otp": { "type": "string", "example": "482910" } } }
            }
          }
        },
        "responses": { "200": { "description": "Email verified" }, "400": { "description": "Invalid or expired OTP" } }
      }
    },
    "/api/user/invite-user/": {
      "post": {
        "tags": ["Users"],
        "summary": "Invite user to organisation",
        "description": "Sends an invitation email. Requires `settings:team:add` permission.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "role_id"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "role_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Invitation sent" }, "403": { "description": "Missing permission" } }
      }
    },
    "/api/website/": {
      "post": {
        "tags": ["Websites"],
        "summary": "Add website",
        "description": "Registers a new website to the organisation. Requires `settings:website:add` permission.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["website_url"],
                "properties": {
                  "website_url": { "type": "string", "format": "uri", "example": "https://example.com" },
                  "website_name": { "type": "string", "example": "Example Site" },
                  "region_id": { "type": "string", "format": "uuid", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Website added", "content": { "application/json": { "schema": { "properties": { "success": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/Website" } } } } } }
        }
      },
      "get": {
        "tags": ["Websites"],
        "summary": "List websites",
        "description": "Returns all websites for the authenticated user's organisation.",
        "parameters": [
          { "name": "website_id", "in": "query", "schema": { "type": "string", "format": "uuid" }, "description": "Filter to a specific website" }
        ],
        "responses": {
          "200": { "description": "List of websites", "content": { "application/json": { "schema": { "properties": { "success": { "type": "boolean" }, "data": { "type": "array", "items": { "$ref": "#/components/schemas/Website" } } } } } } }
        }
      },
      "patch": {
        "tags": ["Websites"],
        "summary": "Update website",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "website_id": { "type": "string", "format": "uuid" }, "website_name": { "type": "string" }, "region_id": { "type": "string", "format": "uuid" }, "enable_aaa": { "type": "boolean" } } }
            }
          }
        },
        "responses": { "200": { "description": "Website updated" } }
      },
      "delete": {
        "tags": ["Websites"],
        "summary": "Delete website",
        "description": "Requires `settings:website:delete` permission.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["website_id"], "properties": { "website_id": { "type": "string", "format": "uuid" } } } } }
        },
        "responses": { "200": { "description": "Website deleted" }, "403": { "description": "Missing permission" } }
      }
    },
    "/api/website/search/": {
      "get": {
        "tags": ["Websites"],
        "summary": "Search websites",
        "parameters": [
          { "name": "search_string", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "organisation_id", "in": "query", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": { "200": { "description": "Matching websites" } }
      }
    },
    "/api/website-audit/": {
      "post": {
        "tags": ["Scans"],
        "summary": "Start a scan",
        "description": "Triggers a new website audit scan. Requires `scan:full_scan:add` permission.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["website_id"],
                "properties": {
                  "website_id": { "type": "string", "format": "uuid" },
                  "scan_type": { "type": "string", "enum": ["quick", "full", "custom"], "default": "full" },
                  "audit_device": { "type": "string", "enum": ["mobile", "desktop"], "default": "desktop" },
                  "max_number_of_pages": { "type": "integer", "default": 0, "description": "0 = unlimited" },
                  "json_audit_list": { "type": "object", "description": "{ audit_types: [...], standards: [...] }", "example": { "audit_types": ["accessibility", "performance", "seo"], "standards": ["wcag2.2aa", "ADA"] } },
                  "json_include_links": { "type": "array", "items": { "type": "string" }, "description": "URL patterns to include" },
                  "json_exclude_links": { "type": "array", "items": { "type": "string" }, "description": "URL patterns to exclude" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Scan started", "content": { "application/json": { "schema": { "properties": { "success": { "type": "boolean" }, "data": { "$ref": "#/components/schemas/WebsiteAudit" } } } } } },
          "403": { "description": "Missing scan permission or scan credit limit reached" }
        }
      }
    },
    "/api/website-audit/history/": {
      "get": {
        "tags": ["Scans"],
        "summary": "Scan history",
        "description": "Returns paginated scan history for a website.",
        "parameters": [
          { "name": "website_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } },
          { "name": "device", "in": "query", "schema": { "type": "string", "enum": ["mobile", "desktop"] } },
          { "name": "enable_aaa", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": { "200": { "description": "Paginated scan list" } }
      }
    },
    "/api/website-audit/latest-audit-status/": {
      "get": {
        "tags": ["Scans"],
        "summary": "Latest scan status",
        "description": "Returns the current status of the most recent or a specific scan. Poll this endpoint to track scan progress.",
        "parameters": [
          { "name": "website_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "audit_id", "in": "query", "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Scan status",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": { "type": "object", "properties": { "status": { "type": "string", "enum": ["scheduled", "in_progress", "completed", "failed", "canceled"] }, "audit_id": { "type": "string", "format": "uuid" } } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/website-audit/rescan/": {
      "post": {
        "tags": ["Scans"],
        "summary": "Re-run a scan",
        "description": "Triggers a rescan using the same config as a previous audit.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["audit_id"], "properties": { "audit_id": { "type": "string", "format": "uuid" } } }
            }
          }
        },
        "responses": { "200": { "description": "Rescan started" } }
      }
    },
    "/api/website-audit/cancel-scan/": {
      "post": {
        "tags": ["Scans"],
        "summary": "Cancel a scan",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["audit_id"], "properties": { "audit_id": { "type": "string", "format": "uuid" } } } } }
        },
        "responses": { "200": { "description": "Scan cancelled" } }
      }
    },
    "/api/results/": {
      "get": {
        "tags": ["Results"],
        "summary": "Get audit results",
        "description": "Returns aggregated audit results (accessibility, performance, SEO, quality scores) for a completed scan.",
        "parameters": [
          { "name": "website_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "audit_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "device", "in": "query", "schema": { "type": "string", "enum": ["mobile", "desktop"] } }
        ],
        "responses": { "200": { "description": "Audit result data" } }
      }
    },
    "/api/accessibility/": {
      "get": {
        "tags": ["Results"],
        "summary": "Get accessibility data",
        "description": "Returns detailed WCAG issue data for a scan.",
        "parameters": [
          { "name": "website_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "audit_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
